# Custom Development Environment Configuration
# ==============================================
# Sourced from ~/.bashrc — works for both remote and desktop setups.

# PATH additions
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/bin:$PATH"

# Environment
export TERM=xterm-256color
export EDITOR=vim
export VISUAL=vim

# Modern CLI tool aliases
alias cat='bat --paging=never'
alias catp='bat'
alias grep='rg'
alias find='fd'
alias ls='ls --color=auto'
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias y='yazi'

# Git aliases
alias gd='git diff'
alias gds='git diff --staged'
alias gl='git log --oneline -20'
alias gs='git status'

# Zellij alias (desktop)
alias zj='zellij'

# Starship prompt
eval "$(starship init bash)"

# fzf integration
[ -f ~/.fzf.bash ] && source ~/.fzf.bash

# fd alias (Ubuntu names it fdfind)
if command -v fdfind &> /dev/null && ! command -v fd &> /dev/null; then
    alias fd='fdfind'
fi

# zoxide — smart cd replacement (replaces cd command)
if command -v zoxide &> /dev/null; then
    eval "$(zoxide init --cmd cd bash)"
fi

# nvm — Node Version Manager
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
